import json
from youtube_transcript_api import YouTubeTranscriptApi

# Put your video id's here.
video_ids = [""]

def get_b58_data(ids):
    dataset = []
    # Initialize the instance
    api_instance = YouTubeTranscriptApi() 
    
    for v_id in ids:
        try:
            # fetch returns a list of FetchedTranscriptSnippet objects
            transcript_objects = api_instance.fetch(v_id, languages=['en'])
            
            # FIX: Use snippet.text (dot notation) instead of snippet['text']
            full_text = " ".join([snippet.text for snippet in transcript_objects])
            
            dataset.append({
                "video_id": v_id,
                "content": full_text.strip(),
                "source": f"https://youtube.com/watch?v={v_id}"
            })
            print(f"Successfully extracted B58 data from: {v_id}")
            
        except Exception as e:
            print(f"Error on {v_id}: {e}")
            
    return dataset

# Run the extraction
b58_knowledge_base = get_b58_data(video_ids)

# Save to file
with open('b58_transcripts.json', 'w') as f:
    json.dump(b58_knowledge_base, f, indent=4)
